generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id   Int    @id @default(autoincrement())
  email String @unique
  password String
}

model Service {
  id                    Int    @id @default(autoincrement())
  cardBackground        String
  headerText            String
  headerTextColor       String
  headerBackgroundColor String
  buttonIconColor       String
  buttonFontColor       String
  serviceIllustration   String
}

model CaseStudy {
  id          Int    @id @default(autoincrement())
  text        String
}

model WorkingProcess {
  id          Int    @id @default(autoincrement())
  title       String
  description String
}

model Team {
  id          Int    @id @default(autoincrement())
  name        String
  position    String
  description String
  photo       String
  linkedin    String
}

model Testimonial {
  id        Int    @id @default(autoincrement())
  name      String
  position  String
  company   String?
  testimony String
}

model Contact {
  id        Int    @id @default(autoincrement())
  name      String
  email     String
  message   String
  type      String
}

model Subscription {
  id        Int    @id @default(autoincrement())
  email     String
}

model SocialMedia {
  id        Int    @id @default(autoincrement())
  link      String
  platform  String
}

model Partner {
  id          Int    @id @default(autoincrement())
  name        String
  logo        String
}